{
  "name": "@agentmetal/mcp",
  "version": "0.3.2",
  "description": "MCP server for AgentMetal — an AI agent can discover, pay (USDC via x402 or card), provision, SSH into, and run commands on its own Linux VPSes over HTTP 402. No signup.",
  "license": "MIT",
  "type": "module",
  "mcpName": "dev.agentmetal/agentmetal",
  "bin": {
    "agentmetal-mcp": "src/index.ts"
  },
  "files": [
    "src",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "model-context-protocol",
    "mcp-server",
    "ai",
    "llm",
    "agent",
    "x402",
    "vps",
    "usdc",
    "ssh",
    "exec",
    "cloud-server",
    "agentmetal"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentmetal/mcp.git"
  },
  "homepage": "https://agentmetal.dev",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "node --test test/*.test.ts",
    "test:watch": "node --test --watch test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "start": "node src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/evm": "^2.17.0",
    "@x402/fetch": "^2.17.0",
    "viem": "^2.54.1",
    "zod": "^4.4.3"
  }
}
